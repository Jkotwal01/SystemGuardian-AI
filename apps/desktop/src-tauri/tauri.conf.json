{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SystemGuardian AI",
  "version": "0.1.0",
  "identifier": "ai.systemguardian.desktop",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SystemGuardian AI",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8765 ws://127.0.0.1:8765; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../../backend/dist/sgai-backend.exe"
    ],
    "externalBin": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "AI-powered OS monitoring platform",
    "longDescription": "SystemGuardian AI continuously monitors your computer, detects problems, predicts failures, and provides actionable recommendations powered by local AI."
  }
}
